# Database Configuration
# For Supabase: use pooler (port 6543) for DATABASE_URL, direct (port 5432) for DIRECT_URL.
# If pooler keeps failing: try direct (port 5432) — get from Supabase Dashboard > Database > Connection string > Session mode
DATABASE_URL=postgresql://ayn_user:ayn_password_2024@localhost:5432/ayn_platform
DIRECT_URL=postgresql://ayn_user:ayn_password_2024@localhost:5432/ayn_platform

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=evidence

# Application Configuration
APP_NAME=Ayn Platform
APP_VERSION=1.0.0
DEBUG=False
ENABLE_DEBUG_ENDPOINTS=False
FRONTEND_URL=http://localhost:3000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Google Gemini AI (primary)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter (fallback AI provider — used if Gemini fails)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=openrouter/free
# Optional — full URL to an OpenAI-compatible POST /chat/completions (your gateway, LiteLLM, or another host). Default: https://openrouter.ai/api/v1/chat/completions
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# Optional, recommended for OpenRouter attribution headers
OPENROUTER_HTTP_REFERER=http://localhost:3000

# Alternate Horus LLM (optional — separate from OPENROUTER_*; use when X-AI-Provider: alt_llm from the app)
# HORUS_ALT_LLM_API_KEY=
# HORUS_ALT_LLM_MODEL=
# HORUS_ALT_LLM_BASE_URL=

# Google OAuth (Login with Google — direct flow shows ayn.vercel.app in Google)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Comma-separated list of allowed Google Workspace domains (optional)
GOOGLE_ALLOWED_DOMAINS=
# Frontend URL for OAuth redirect validation (use https://ayn.vercel.app in production)
FRONTEND_URL=https://ayn.vercel.app
